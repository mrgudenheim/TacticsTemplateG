static func note_to_pitch(midi_note: int, fine_tune: int) -> int:
	var adjusted := midi_note * 256 + fine_tune
	# FFT's midi_to_spu_pitch_lookup (FUN_80017424) does `andi 0x7FFF`
	# internally for the octave_index path and `andi 0xFF` for the
	# fine_byte path. Neither clamps a negative `adjusted` to 0.
	# GDScript's signed-int `>>` + `&` ops produce the same low-bit
	# results as MIPS `andi`, so do NOT clamp here — inputs whose s16
	# reinterpretation is negative (e.g. protect_no_music's
	# pitch_base = 33357 ≡ -32179) must reach the lookup unmasked.
	var octave_index := (adjusted >> 8) & 0x7F
	var fine_byte := adjusted & 0xFF
	var semitone: int = SEMITONE_LOOKUP[octave_index]
	var octave_shift: int = 6 - OCTAVE_SHIFT_LOOKUP[octave_index]
	var table_idx := semitone * 256 + fine_byte
	if table_idx >= TABLE.size():
		table_idx = TABLE.size() - 1
	var base_pitch := TABLE[table_idx]
	if octave_shift >= 0:
		return base_pitch >> octave_shift
	else:
		return base_pitch << (-octave_shift)
