## note_lookup.gd — FFT Note-handler ROM lookup tables.
##
## DAT_80028e70 (256 bytes) and DAT_80028d8c (256 bytes), copied from
## BATTLE.BIN. They drive FFT's Note-handler natural-MIDI byte composition
## at L800153cc-L80015410:
##   v0 = lbu slot+0x7E low byte           ← Godot: bmidi_baseline_byte
##   v1 = byte at DAT_80028e70 + key       ← lookup_e70[key]
##   v0 = (v0 + v1) & 0xFF                  ← natural-MIDI byte
##   a0 = byte at DAT_80028d8c + key       ← lookup_d8c[key]
##   if (a0 == 0): jump to alternate path L8001541c

